{
  "schema_version": "sofunny-profile.v1",
  "profile_name": "default-character-gif",
  "profile_type": "generic",
  "unknown_keys_policy": "fail",
  "default_canvas": "384x384",
  "default_background": "#00ff00",
  "default_keypose_count": {
    "smoke": 6,
    "production": 12
  },
  "style_rules": [
    "preserve canonical character identity",
    "keep full body inside each frame",
    "use clean solid background for deterministic removal",
    "no text, watermark, UI, labels, or frame borders"
  ],
  "identity_features": [
    "same face/head silhouette",
    "same body proportions",
    "same costume and accessories",
    "same palette family and line weight",
    "same tail/prop attachment when present"
  ],
  "motion_defaults": {
    "default_action": "generic_loop",
    "duration_ms": 90,
    "actions": {
      "generic_loop": {
        "requires_manual_phase_review": true,
        "phases_6": [
          "anticipation",
          "main_action",
          "overshoot",
          "settle",
          "return",
          "loop"
        ],
        "phases_12": [
          "anticipation",
          "prepare",
          "main_action_a",
          "main_action_b",
          "overshoot",
          "settle",
          "return_a",
          "return_b",
          "loop_prepare",
          "loop_return",
          "settle",
          "loop"
        ],
        "required_global_checks": [
          "same_character_all_frames",
          "readable_action",
          "clean_loop"
        ],
        "phase_semantics": {
          "anticipation": "small preparation pose before the main action",
          "prepare": "secondary preparation pose that keeps identity stable",
          "main_action": "readable peak or primary action phase",
          "main_action_a": "first half of the primary action",
          "main_action_b": "second half of the primary action",
          "overshoot": "overshoot after the action peak",
          "settle": "settle pose after motion energy decreases",
          "return": "return pose toward loop start",
          "return_a": "first return phase toward loop start",
          "return_b": "second return phase toward loop start",
          "loop_prepare": "pose preparing the final loop connection",
          "loop_return": "final frame connects cleanly back to frame 0",
          "loop": "loop connection phase"
        },
        "required_visual_changes": [
          "same character remains recognizable in every frame",
          "main action is visually readable",
          "loop return connects without a jump cut"
        ]
      }
    }
  },
  "thresholds": {
    "provider_preflight": {
      "green_tolerance": 8,
      "max_bbox_bottom_range_px": 4.0,
      "max_bbox_width_range_px": 24.0,
      "max_bbox_height_range_px": 24.0,
      "edge_margin_px": 1
    },
    "jitter": {
      "max_bbox_bottom_range_px": 1.0,
      "max_anchor_center_x_range_px": 8.0
    },
    "visual_stability": {
      "max_bbox_top_range_px": 16.0,
      "max_bbox_height_range_px": 22.0,
      "max_bbox_width_range_px": 18.0,
      "max_top_centroid_x_range_px": 10.0,
      "max_mid_centroid_x_range_px": 10.0,
      "max_top_centroid_y_range_px": 20.0,
      "max_mid_centroid_y_range_px": 20.0,
      "max_alpha_area_range_ratio": 0.12
    },
    "body_tail": {
      "max_bbox_width_range_px": 18.0,
      "max_bbox_height_range_px": 16.0,
      "max_alpha_area_ratio": 0.14,
      "min_right_margin_px": 8,
      "min_tail_region_width_px": 0,
      "min_tail_region_alpha_area": 0,
      "alpha_threshold": 96
    },
    "identity_consistency": {
      "min_pair_ssim": 0.52,
      "max_pair_color_distance": 0.14,
      "max_bbox_width_range_px": 24.0,
      "max_bbox_height_range_px": 24.0,
      "max_alpha_area_range_ratio": 0.16,
      "max_bbox_aspect_range": 0.20,
      "min_reference_ssim": 0.40
    },
    "action_contract": {}
  },
  "asset_paths": {}
}
